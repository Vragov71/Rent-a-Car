@page "{id}"
@model RentACar.Pages.Admin.Users.EditModel
@{
    ViewData["Title"] = "Редактирай потребител";
}

<h2 class="mb-4">Редактирай потребител</h2>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <input type="hidden" asp-for="AppUser.Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="AppUser.FirstName" class="form-label">Собствено име</label>
                <input asp-for="AppUser.FirstName" class="form-control" />
                <span asp-validation-for="AppUser.FirstName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="AppUser.LastName" class="form-label">Фамилно име</label>
                <input asp-for="AppUser.LastName" class="form-control" />
                <span asp-validation-for="AppUser.LastName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="AppUser.Email" class="form-label">Имейл</label>
                <input asp-for="AppUser.Email" class="form-control" type="email" />
                <span asp-validation-for="AppUser.Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="AppUser.PhoneNumber" class="form-label">Телефон</label>
                <input asp-for="AppUser.PhoneNumber" class="form-control" />
            </div>
            <button type="submit" class="btn btn-dark">Запази</button>
            <a asp-page="Index" class="btn btn-outline-secondary ms-2">Отказ</a>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
