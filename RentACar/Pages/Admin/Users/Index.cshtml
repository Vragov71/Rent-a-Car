@page
@model RentACar.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Управление на потребители";
}

<h2 class="mb-4">Управление на потребители</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Потребителско име</th>
            <th>Имена</th>
            <th>Имейл</th>
            <th>Телефон</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model.Users)
        {
            <tr>
                <td>@user.UserName</td>
                <td>@user.FirstName @user.LastName</td>
                <td>@user.Email</td>
                <td>@user.PhoneNumber</td>
                <td>
                    <a asp-page="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-secondary">Редактирай</a>
                    <a asp-page="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger">Изтрий</a>
                </td>
            </tr>
        }
    </tbody>
</table>
