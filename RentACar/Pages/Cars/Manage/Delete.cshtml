@page "{id:int}"
@model RentACar.Pages.Cars.Manage.DeleteModel
@{
    ViewData["Title"] = "Изтрий автомобил";
}

<h2 class="mb-4">Изтриване на автомобил</h2>

<div class="alert alert-warning">
    Сигурен ли си, че искаш да изтриеш <strong>@Model.Car.Make @Model.Car.Model (@Model.Car.Year)</strong>?
</div>

<form method="post">
    <input type="hidden" asp-for="Car.Id" />
    <button type="submit" class="btn btn-danger">Изтрий</button>
    <a asp-page="Index" class="btn btn-outline-secondary ms-2">Отказ</a>
</form>
